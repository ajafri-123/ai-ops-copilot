# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=aiops
POSTGRES_USER=aiops
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins (no wildcard when credentials are used)
# CORS_ORIGINS=["http://localhost:3000","https://your-app.example.com"]

# ── JWT ────────────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── AI integrations ────────────────────────────────────────────────────────
# Leave blank to use the intelligent mock (no API key needed)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Celery background jobs ─────────────────────────────────────────────────
# Number of concurrent Celery worker processes
CELERY_CONCURRENCY=4

# Set to true to have the Beat scheduler fire demo alerts automatically
DEMO_PERIODIC_ALERTS=false
# How often the periodic demo fires (seconds)
DEMO_ALERT_INTERVAL_SECONDS=120

# Set to true to automatically queue AI analysis whenever a new incident is created
AUTO_ANALYZE_NEW_INCIDENTS=false

# ── Flower monitoring UI (http://localhost:5555) ───────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
